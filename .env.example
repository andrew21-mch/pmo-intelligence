# Application
APP_ENV=development
APP_SECRET_KEY=change-me-in-production
LOG_LEVEL=INFO

# Database
DATABASE_URL=postgresql+asyncpg://pmo:pmo_secret@postgres:5432/pmo_intelligence

# Qdrant
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=pmo_documents

# LLM — local Ollama (default, no API key needed)
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://ollama:11434/v1
OLLAMA_MODEL=llama3.2

# Optional: switch to OpenAI instead
# LLM_PROVIDER=openai
# OPENAI_API_KEY=sk-your-key-here
# OPENAI_MODEL=gpt-4o-mini

# Jira — required for real Jira sync
JIRA_BASE_URL=https://your-domain.atlassian.net
JIRA_EMAIL=your-email@example.com
JIRA_API_TOKEN=your-jira-api-token

# Sync
JIRA_SYNC_INTERVAL_MINUTES=60
